---
import { GITHUB_URL, SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const today = new Date();
const rssHref = `${import.meta.env.BASE_URL}rss.xml`;
---

<footer class="site-footer">
	<div class="footer-shell surface-card">
		<div>
			<p class="footer-kicker">{SITE_TITLE}</p>
			<p class="footer-copy">{SITE_DESCRIPTION}</p>
		</div>
		<div class="footer-meta">
			<a href={GITHUB_URL} target="_blank" rel="noreferrer">GitHub</a>
			<a href={rssHref}>RSS</a>
		</div>
		<p class="copyright">&copy; {today.getFullYear()} {SITE_AUTHOR}. Built with Astro and GitHub Pages.</p>
	</div>
</footer>
<style>
	.site-footer {
		padding: 0 1rem 2rem;
	}

	.footer-shell {
		width: min(1120px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 1.5rem;
		display: grid;
		gap: 1rem;
	}

	.footer-kicker {
		margin: 0 0 0.4rem;
		font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
		font-size: 1.4rem;
		font-weight: 700;
		color: rgb(var(--ink));
	}

	.footer-copy,
	.copyright {
		margin: 0;
		color: rgb(var(--muted-ink));
	}

	.footer-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
	}

	.footer-meta a {
		color: rgb(var(--ink));
		text-decoration: none;
	}

	@media (max-width: 560px) {
		.site-footer {
			padding-inline: 0.75rem;
		}

		.footer-shell {
			width: calc(100% - 1rem);
			padding: 1.2rem;
		}
	}
</style>
