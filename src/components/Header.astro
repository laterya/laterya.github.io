---
import { GITHUB_URL, NAV_LINKS, SITE_TAGLINE, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const rssHref = `${import.meta.env.BASE_URL}rss.xml`;
---

<header class="site-header">
	<nav>
		<a class="brand" href={import.meta.env.BASE_URL}>
			<span class="brand-mark">{SITE_TITLE}</span>
			<span class="brand-sub">{SITE_TAGLINE}</span>
		</a>
		<div class="internal-links">
			{
				NAV_LINKS.map((link) => (
					<HeaderLink href={link.href}>{link.label}</HeaderLink>
				))
			}
		</div>
		<div class="utility-links">
			<a class="utility-pill" href={rssHref}>RSS</a>
			<a class="utility-pill" href={GITHUB_URL} target="_blank" rel="noreferrer">GitHub</a>
		</div>
	</nav>
</header>
<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		padding: 1rem;
	}

	nav {
		width: min(1120px, calc(100% - 2rem));
		margin: 0 auto;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
		padding: 1rem 1.25rem;
		border: 1px solid var(--border);
		border-radius: 24px;
		background: rgba(250, 246, 239, 0.82);
		backdrop-filter: blur(18px);
		box-shadow: 0 18px 42px rgba(67, 44, 24, 0.08);
	}

	.brand {
		display: inline-flex;
		flex-direction: column;
		gap: 0.1rem;
		color: rgb(var(--ink));
		text-decoration: none;
	}

	.brand-mark {
		font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
		font-size: 1.15rem;
		font-weight: 700;
		letter-spacing: -0.03em;
	}

	.brand-sub {
		font-size: 0.78rem;
		color: rgb(var(--muted-ink));
	}

	.internal-links,
	.utility-links {
		display: flex;
		align-items: center;
	}

	.internal-links {
		justify-content: center;
		gap: 0.35rem;
	}

	.utility-links {
		gap: 0.6rem;
	}

	.utility-pill {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.5rem;
		padding: 0 1rem;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: rgba(255, 255, 255, 0.72);
		color: rgb(var(--ink));
		font-size: 0.9rem;
		text-decoration: none;
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			background-color 180ms ease;
	}

	.utility-pill:hover {
		transform: translateY(-1px);
		border-color: rgba(var(--accent-rgb), 0.35);
		background: rgba(255, 248, 244, 0.95);
	}

	@media (max-width: 880px) {
		nav {
			grid-template-columns: 1fr;
			justify-items: start;
		}

		.internal-links {
			justify-content: flex-start;
			flex-wrap: wrap;
		}

		.utility-links {
			width: 100%;
			justify-content: flex-start;
		}
	}

	@media (max-width: 560px) {
		.site-header {
			padding: 0.75rem;
		}

		nav {
			width: calc(100% - 1rem);
			padding: 0.9rem 1rem;
		}

		.brand-sub {
			display: none;
		}
	}
</style>
