---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_LOCALE, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang={SITE_LOCALE}>
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.archive-page {
				display: grid;
				gap: 1.25rem;
			}

			.archive-intro,
			.post-card {
				padding: 1.35rem;
			}

			.archive-intro h1 {
				margin-bottom: 0.7rem;
				font-size: clamp(3rem, 7vw, 5.4rem);
			}

			.archive-intro p:last-child {
				max-width: 38rem;
				margin-bottom: 0;
				color: rgb(var(--muted-ink));
			}

			.archive-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
			}

			.post-card {
				display: grid;
			}

			.post-card a {
				display: grid;
				gap: 0.9rem;
				color: inherit;
				text-decoration: none;
			}

			.post-card img {
				aspect-ratio: 16 / 10;
				width: 100%;
				object-fit: cover;
				border-radius: 18px;
			}

			.post-copy {
				display: grid;
				gap: 0.5rem;
			}

			.post-copy h2 {
				margin: 0;
				font-size: 2rem;
			}

			.post-copy p:last-child {
				margin-bottom: 0;
				color: rgb(var(--muted-ink));
			}

			.post-date {
				margin: 0;
				font-size: 0.85rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: rgb(var(--muted-ink));
			}

			@media (max-width: 820px) {
				.archive-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="archive-page">
			<section class="archive-intro surface-card">
				<p class="eyebrow">ARCHIVE</p>
				<h1>所有文章</h1>
				<p>按时间整理的写作归档。默认只保留完成度足够高、日后仍值得回看的内容。</p>
			</section>
			<section class="archive-grid">
					{
						posts.map((post) => (
							<article class="post-card surface-card">
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image
											width={720}
											height={420}
											src={post.data.heroImage}
											alt={post.data.title}
										/>
									)}
									<div class="post-copy">
										<p class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<h2>{post.data.title}</h2>
										<p>{post.data.description}</p>
									</div>
								</a>
							</article>
						))
					}
			</section>
		</main>
		<Footer />
	</body>
</html>
