---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { GITHUB_URL, SITE_DESCRIPTION, SITE_LOCALE, SITE_TAGLINE, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latestPosts = posts.slice(0, 3);
---

<!doctype html>
<html lang={SITE_LOCALE}>
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home-page">
			<section class="hero surface-card">
				<div class="hero-copy">
					<p class="eyebrow">PERSONAL LOGBOOK</p>
					<h1>把代码、产品和长期写作，放进同一个安静而可靠的空间。</h1>
					<p class="hero-intro">
						{SITE_TAGLINE}。这里不追求信息轰炸，而是把值得沉淀的内容按时间、主题和项目持续整理出来。
					</p>
					<div class="hero-actions">
						<a class="button" href="/blog">进入文章归档</a>
						<a class="button button-secondary" href={GITHUB_URL} target="_blank" rel="noreferrer">
							查看 GitHub
						</a>
					</div>
				</div>
				<div class="hero-panel">
					<p class="panel-label">站点特性</p>
					<ul class="hero-metrics">
						<li>
							<span>Astro</span>
							<strong>静态生成</strong>
						</li>
						<li>
							<span>Markdown / MDX</span>
							<strong>内容优先</strong>
						</li>
						<li>
							<span>RSS</span>
							<strong>长期订阅</strong>
						</li>
					</ul>
				</div>
			</section>

			<section class="focus-grid">
				<article class="surface-card focus-card">
					<p class="eyebrow">工程实践</p>
					<h2>拆解一套能长期维护的技术工作流</h2>
					<p>记录那些真正能复用的工程方法，而不是只适合一时热度的技巧。</p>
				</article>
				<article class="surface-card focus-card">
					<p class="eyebrow">产品观察</p>
					<h2>从功能表象往下挖一层</h2>
					<p>关注产品决策背后的结构、取舍与用户体验，而不只盯着 feature list。</p>
				</article>
				<article class="surface-card focus-card">
					<p class="eyebrow">长期项目</p>
					<h2>让每次迭代都能留下清晰痕迹</h2>
					<p>把零散思考变成可以回看的系统，帮助项目在时间里积累而不是遗失。</p>
				</article>
			</section>

			<section class="latest">
				<div class="section-head">
					<div>
						<p class="eyebrow">LATEST NOTES</p>
						<h2>最近更新</h2>
					</div>
					<a class="section-link" href="/blog">查看全部文章</a>
				</div>
				<div class="latest-grid">
					{
						latestPosts.map((post) => (
							<article class="surface-card post-card">
								<a class="post-link" href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image
											src={post.data.heroImage}
											width={720}
											height={480}
											alt={post.data.title}
										/>
									)}
									<div class="post-body">
										<p class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										<h3>{post.data.title}</h3>
										<p>{post.data.description}</p>
									</div>
								</a>
							</article>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
<style>
	.home-page {
		display: grid;
		gap: 1.5rem;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.9fr);
		gap: 1.5rem;
		padding: clamp(1.5rem, 4vw, 3rem);
		position: relative;
		overflow: hidden;
	}

	.hero::after {
		content: "";
		position: absolute;
		inset: auto -6rem -7rem auto;
		width: 16rem;
		height: 16rem;
		border-radius: 999px;
		background: radial-gradient(circle, rgba(var(--accent-rgb), 0.18), transparent 68%);
	}

	.hero-copy {
		position: relative;
		z-index: 1;
	}

	.hero h1 {
		max-width: 12ch;
		margin-bottom: 1rem;
		font-size: clamp(3rem, 7vw, 5.8rem);
	}

	.hero-intro {
		max-width: 40rem;
		margin-bottom: 1.5rem;
		font-size: 1.05rem;
		color: rgb(var(--muted-ink));
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}

	.hero-panel {
		display: grid;
		align-content: start;
		gap: 1rem;
		padding: 1.25rem;
		border-radius: 24px;
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.84), rgba(248, 240, 232, 0.92));
		border: 1px solid rgba(var(--accent-rgb), 0.12);
	}

	.panel-label {
		margin: 0;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgb(var(--muted-ink));
	}

	.hero-metrics {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0.9rem;
	}

	.hero-metrics li {
		padding-bottom: 0.9rem;
		border-bottom: 1px solid rgba(var(--accent-rgb), 0.12);
	}

	.hero-metrics li:last-child {
		padding-bottom: 0;
		border-bottom: 0;
	}

	.hero-metrics span,
	.post-date {
		display: block;
		margin-bottom: 0.2rem;
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgb(var(--muted-ink));
	}

	.hero-metrics strong {
		font-size: 1.1rem;
		color: rgb(var(--ink));
	}

	.focus-grid,
	.latest-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.focus-card,
	.post-card {
		padding: 1.35rem;
	}

	.focus-card h2 {
		margin-bottom: 0.7rem;
		font-size: 1.8rem;
	}

	.focus-card p:last-child {
		margin-bottom: 0;
		color: rgb(var(--muted-ink));
	}

	.section-head {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.section-head h2 {
		margin-bottom: 0;
		font-size: clamp(2rem, 4vw, 3rem);
	}

	.section-link {
		font-size: 0.95rem;
	}

	.post-card {
		padding: 0.9rem;
	}

	.post-link {
		display: grid;
		gap: 0.9rem;
		color: inherit;
		text-decoration: none;
	}

	.post-link img {
		aspect-ratio: 16 / 10;
		object-fit: cover;
		border-radius: 18px;
	}

	.post-body {
		padding: 0.2rem 0.2rem 0.4rem;
	}

	.post-body h3 {
		margin-bottom: 0.55rem;
		font-size: 1.55rem;
	}

	.post-body p:last-child {
		margin-bottom: 0;
		color: rgb(var(--muted-ink));
	}

	@media (max-width: 960px) {
		.hero,
		.focus-grid,
		.latest-grid {
			grid-template-columns: 1fr;
		}

		.hero h1 {
			max-width: 10ch;
		}
	}

	@media (max-width: 640px) {
		.section-head {
			align-items: start;
			flex-direction: column;
		}

		.hero {
			padding: 1.25rem;
		}
	}
</style>
